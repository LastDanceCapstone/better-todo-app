{
  "expo": {
    "name": "Prioritize",
    "slug": "mobile",
    "scheme": "prioritize",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.london.prioritize",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Prioritize uses your microphone so you can describe tasks with your voice.",
        "NSCalendarsUsageDescription": "Prioritize uses Calendar access to sync your due-date tasks to your Apple Calendar and keep those events updated.",
        "NSUserNotificationUsageDescription": "Prioritize sends reminders for upcoming and overdue tasks, plus optional daily summaries, so you can stay on track."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-notifications",
      "@sentry/react-native/expo",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.857743457833-t9fdc2a1gdgluk0gapo1fu839ejfge4h"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4d7852b5-0757-4fe8-ab54-d9baf872ea73"
      }
    }
  }
}
