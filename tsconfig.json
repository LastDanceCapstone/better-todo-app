{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",                 // ✅ required for paths to work
    "paths": {
      "@/*": ["app/*"]              // ✅ alias @ → app folder
    },
    "types": ["expo-router"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
